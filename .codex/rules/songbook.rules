prefix_rule(
    pattern=["gh", "pr", ["list", "view", "diff", "checks"]],
    decision="allow",
    justification="Read-only pull-request inspection for Songbook Platform repositories.",
    match=[
        "gh pr list --repo mjdominiczak/songbook",
        "gh pr view 42 --repo mjdominiczak/songbook",
        "gh pr diff 42 --repo mjdominiczak/songbook",
        "gh pr checks 42 --repo mjdominiczak/songbook",
        "gh pr view 6 --repo mjdominiczak/songs-manager",
        "gh pr diff 2 --repo mjdominiczak/songbook-backend",
    ],
    not_match=[
        "gh pr create --repo mjdominiczak/songbook",
        "gh pr merge 42 --repo mjdominiczak/songbook",
    ],
)

prefix_rule(
    pattern=["gh", "run", ["list", "view", "watch"]],
    decision="allow",
    justification="Read-only GitHub Actions inspection for Songbook Platform repositories.",
    match=[
        "gh run list --repo mjdominiczak/songbook",
        "gh run view 123 --repo mjdominiczak/songbook",
        "gh run watch 123 --repo mjdominiczak/songbook",
        "gh run list --repo mjdominiczak/songs-manager",
        "gh run list --repo mjdominiczak/songbook-backend",
    ],
)

prefix_rule(
    pattern=["gh", "pr", "create"],
    decision="prompt",
    justification="Auto-review PR creation so the destination remains within the Songbook Platform repositories.",
    match=[
        "gh pr create --repo mjdominiczak/songbook --base master --head feature/example",
        "gh pr create --repo mjdominiczak/songs-manager --base main --head feature/example",
        "gh pr create --repo mjdominiczak/songbook-backend --base main --head feature/example",
    ],
    not_match=["gh pr merge 42 --repo mjdominiczak/songbook"],
)

prefix_rule(
    pattern=["gh", "issue", ["list", "view"]],
    decision="allow",
    justification="Read-only issue inspection is non-destructive.",
    match=[
        "gh issue list --repo mjdominiczak/songbook",
        "gh issue view 42 --repo mjdominiczak/songbook",
        "gh issue list --repo mjdominiczak/songs-manager",
        "gh issue view 2 --repo mjdominiczak/songbook-backend",
    ],
    not_match=[
        "gh issue edit 42 --repo mjdominiczak/songbook --add-label ready-for-agent",
        "gh issue delete 42 --repo mjdominiczak/songbook",
    ],
)

prefix_rule(
    pattern=["gh", "issue", ["create", "edit", "comment", "close", "reopen"]],
    decision="prompt",
    justification="Auto-review issue mutations so the destination remains within the Songbook Platform repositories.",
    match=[
        "gh issue create --repo mjdominiczak/songbook --title example --body example",
        "gh issue edit 42 --repo mjdominiczak/songbook --add-label ready-for-agent",
        "gh issue comment 42 --repo mjdominiczak/songbook --body update",
        "gh issue close 42 --repo mjdominiczak/songbook",
        "gh issue reopen 42 --repo mjdominiczak/songbook",
        "gh issue create --repo mjdominiczak/songs-manager --title example --body example",
        "gh issue edit 2 --repo mjdominiczak/songbook-backend --add-label ready-for-agent",
    ],
    not_match=["gh issue delete 42 --repo mjdominiczak/songbook"],
)

prefix_rule(
    pattern=["gh", "label", "list"],
    decision="allow",
    justification="Reading Songbook Platform repository label vocabularies is non-destructive.",
    match=[
        "gh label list --repo mjdominiczak/songbook",
        "gh label list --repo mjdominiczak/songs-manager",
        "gh label list --repo mjdominiczak/songbook-backend",
    ],
    not_match=[
        "gh label create example --repo mjdominiczak/songbook",
        "gh label delete example --repo mjdominiczak/songbook",
    ],
)

prefix_rule(
    pattern=["gh", "project", ["list", "view", "field-list", "item-list"]],
    decision="allow",
    justification="Read-only inspection of the personal Songbook Platform Project is non-destructive.",
    match=[
        "gh project view 2 --owner mjdominiczak",
        "gh project field-list 2 --owner mjdominiczak",
        "gh project item-list 2 --owner mjdominiczak",
    ],
    not_match=["gh project delete 2 --owner mjdominiczak"],
)

prefix_rule(
    pattern=["gh", "project", ["edit", "link", "item-add", "item-edit"]],
    decision="prompt",
    justification="Auto-review bounded coordination changes to personal Songbook Platform Project #2.",
    match=[
        "gh project edit 2 --owner mjdominiczak --description example",
        "gh project link 2 --owner mjdominiczak --repo mjdominiczak/songbook",
        "gh project item-add 2 --owner mjdominiczak --url https://github.com/mjdominiczak/songbook/issues/22",
    ],
    not_match=[
        "gh project delete 2 --owner mjdominiczak",
        "gh project close 2 --owner mjdominiczak",
        "gh project field-delete 2 --owner mjdominiczak --id example",
        "gh project item-delete 2 --owner mjdominiczak --id example",
    ],
)

prefix_rule(
    pattern=["gh", "auth", "status"],
    decision="allow",
    justification="Checking GitHub CLI authentication is non-destructive.",
    match=["gh auth status"],
)

prefix_rule(
    pattern=["git", "fetch"],
    decision="allow",
    justification="Fetching remote refs does not update the working tree or remote repository.",
    match=["git fetch origin"],
    not_match=["git push origin feature/example"],
)

prefix_rule(
    pattern=["git", "switch"],
    decision="prompt",
    justification="Auto-review normal branch switches and gate flags that discard local changes.",
    match=[
        "git switch feature/example",
        "git switch -c feature/example",
    ],
    not_match=["git reset --hard"],
)

prefix_rule(
    pattern=["git", "ls-remote"],
    decision="allow",
    justification="Reading remote refs is non-destructive.",
    match=["git ls-remote origin"],
)

prefix_rule(
    pattern=[".\\gradlew.bat"],
    decision="prompt",
    justification="Auto-review Gradle tasks so external script and configuration overrides stay gated.",
    match=[
        ".\\\\gradlew.bat assembleDebug",
        ".\\\\gradlew.bat testDebugUnitTest",
    ],
)
