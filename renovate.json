{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Europe/Warsaw",
  "labels": [
    "dependencies"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Keep related AndroidX updates in one PR.",
      "matchPackageNames": [
        "/^androidx\\./"
      ],
      "groupName": "AndroidX dependencies"
    },
    {
      "description": "Keep related Retrofit updates in one PR.",
      "matchPackageNames": [
        "/^com\\.squareup\\.retrofit2:/"
      ],
      "groupName": "Retrofit dependencies"
    }
  ]
}
